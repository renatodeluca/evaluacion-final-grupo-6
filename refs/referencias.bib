@article{crespo_disminucion_2024,
  title = {Disminución En La {{Natalidad}}: {{Posibles}} Efectos En El Futuro de {{Chile}}},
  shorttitle = {Disminución En La {{Natalidad}}},
  author = {Crespo, Fernando A. and Soto Márquez, Mónica},
  date = {2024-10-11},
  journaltitle = {Observatorio Económico},
  shortjournal = {Obs. econom.},
  volume = {1},
  number = {192},
  pages = {4--7},
  issn = {0719-9597, 0719-9597},
  doi = {10.11565/oe.v1i192.560},
  url = {https://www.observatorioeconomico.cl/index.php/oe/article/view/560},
  urldate = {2026-06-24},
  abstract = {Este artículo examina la tendencia decreciente en la tasa de natalidad en Chile y sus implicaciones futuras. Se analiza la evolución histórica de la tasa de natalidad y fecundidad desde 1960 hasta 2022, destacando la caída por debajo del nivel de reemplazo generacional. El estudio aborda factores como la postergación de la maternidad, el aumento de nacimientos de madres extranjeras y el envejecimiento poblacional. Se discuten las consecuencias potenciales en áreas como el sistema de pensiones, la productividad laboral, el ahorro nacional y la inflación, planteando desafíos significativos para las políticas públicas futuras.}
}

